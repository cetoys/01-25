{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", "artifacts/**", ".next/**"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^test"]
    },
    "clean": {
      "cache": false
    },
    "postinstall": {
      "cache": false
    }
  }
}
